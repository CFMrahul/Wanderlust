<%- layout("layouts/boilerplate") %><body>
  <div class="row mt-4">
    <div class="col-8 offset-2">
      <h3>Edit your listings.</h3>
      <form
        class="needs-validation"
        method="post"
        action="/listings/<%= listing._id %>?_method=PUT"
        novalidate
      >
        <div class="md-3">
          <label for="title" class="font-label">Title</label>
          <input
            class="form-control"
            name="listing[title]"
            type="text"
            value="<%= listing.title %>"
            required
          />
          <div class="valid-feedback">Looks good!</div>
          <div class="invalid-feedback">Please enter description.</div>
        </div>
        <div class="md-3">
          <label for="description" class="font-label">Description</label>
          <textarea class="form-control" name="listing[description]" required>
      <%=listing.description%></textarea>
      <div class="valid-feedback">Looks good!</div>
        </div>
        <div class="md-3">
          <label for="image" class="font-label">Image</label>
          <input
            class="form-control"
            name="listing[image]"
            type="text"
            value="<%= listing.image %>"
            required
          />
          <div class="invalid-feedback">Please upload valid image.</div>
        </div>
        <div class="row">
          <div class="md-3 col-md-4">
            <label for="number" class="font-label">Number</label>
            <input
              class="form-control"
              name="listing[price]"
              type="number"
              value="<%= listing.price %>"
              required
            />
            <div class="invalid-feedback">Please enter valid price</div>
          </div>
          <div class="md-3 col-md-8">
            <label for="country" class="font-label">Country</label>
            <input
              class="form-control"
              name="listing[country]"
              type="text"
              value="<%= listing.country %>"
              required
            />
            <div class="invalid-feedback">Please enter valid country</div>
          </div>
        </div>

        <div class="md-3">
          <label for="location" class="font-label">Location</label>
          <input
            class="form-control"
            name="listing[location]"
            type="text"
            value="<%= listing.location %>"
            required
          />
          <div class="invalid-feedback">Please enter valid location</div>
        </div>
        <button class="btn btn-dark edit-btn mt-4">submit</button>
      </form>
    </div>
  </div>
 
</body>
